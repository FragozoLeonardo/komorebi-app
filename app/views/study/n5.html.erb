<div class="min-h-screen transition-colors duration-500">
  <header class="mx-auto mb-16 flex max-w-5xl items-center justify-between border-b border-[var(--app-border)] px-6 py-12">
    <div>
      <p class="mb-3 text-[11px] uppercase tracking-[0.35em] text-[var(--app-muted)]">
        Komorebi Japanese Study
      </p>
      <h1 class="text-4xl font-serif tracking-tight text-[var(--app-text)]">
        Kanji N5
      </h1>
    </div>

    <%= render "shared/theme_toggle" %>
  </header>

  <main class="mx-auto max-w-5xl px-6 pb-24">
    <div class="grid grid-cols-2 gap-x-12 gap-y-20 text-center sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      <% @kanjis.each do |k| %>
        <%= render "study/kanji_card", kanji: k %>
      <% end %>
    </div>
  </main>
</div>
