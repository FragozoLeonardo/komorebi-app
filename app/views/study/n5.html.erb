<div class="min-h-screen bg-[#FDFCF8] text-slate-900 transition-colors duration-500 dark:bg-slate-950 dark:text-slate-100">
  <header class="mx-auto mb-16 flex max-w-5xl items-center justify-between border-b border-slate-200 px-6 py-12 dark:border-slate-800">
    <div>
      <p class="mb-3 text-[11px] uppercase tracking-[0.35em] text-slate-400 dark:text-slate-500">
        Komorebi Japanese Study
      </p>
      <h1 class="text-4xl font-serif tracking-tight text-slate-900 dark:text-slate-100">
        Kanji N5
      </h1>
    </div>

    <%= render "shared/theme_toggle" %>
  </header>

  <main class="mx-auto max-w-5xl px-6 pb-24">
    <section class="mb-14 max-w-2xl">
    </section>

    <div class="grid grid-cols-2 gap-x-12 gap-y-20 text-center sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      <% @kanjis.each do |k| %>
        <%= render "study/kanji_card", kanji: k %>
      <% end %>
    </div>
  </main>
</div>