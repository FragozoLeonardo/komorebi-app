<%= link_to kanji_path(kanji), class: "group block cursor-pointer" do %>
  <div class="text-7xl font-light text-[var(--app-text)] transition-all duration-300 group-hover:scale-110 group-hover:text-[var(--app-accent)]">
    <%= kanji.kanji %>
  </div>

  <div class="mt-4 text-[10px] font-light uppercase tracking-[0.3em] text-[var(--app-muted)]">
    <%= kanji.meaning %>
  </div>
<% end %>
